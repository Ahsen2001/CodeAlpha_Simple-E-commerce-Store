<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <!-- Title and Meta Tags for SEO -->
    <title><%= title %></title>
    <meta name="description" content="A premium and immersive e-commerce experience">
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Custom Styles -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg glass-nav fixed-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">🛍️ LuxeStore</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link active" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Shop</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link cart-icon" href="/cart" id="cartToggle">
                            🛒 <span class="badge rounded-pill bg-primary" id="cartCount">0</span>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="container mt-5 pt-5 mb-5">
        <div class="text-center py-5">
            <h1 class="display-4 fw-bold">Discover Premium Picks</h1>
            <p class="lead text-muted">Elevate your lifestyle with our curated collection.</p>
        </div>
        
        <div class="row g-4">
            <% if (products && products.length > 0) { %>
                <% products.forEach(product => { %>
                    <div class="col-12 col-md-6 col-lg-3">
                        <div class="card h-100 border-0 shadow-sm product-card">
                            <div class="img-wrapper position-relative overflow-hidden" style="height: 250px; border-radius: 8px 8px 0 0;">
                                <img src="<%= product.image %>" class="card-img-top w-100 h-100 object-fit-cover" alt="<%= product.name %>" style="transition: transform 0.5s ease;">
                            </div>
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h5 class="card-title fw-bold mb-0 text-truncate"><%= product.name %></h5>
                                    <span class="badge bg-light text-dark border"><i class="text-warning">★</i> <%= product.rating %></span>
                                </div>
                                <p class="card-text fw-bold text-primary fs-5 mb-3">$<%= product.price.toFixed(2) %></p>
                                <a href="/product/<%= product.id %>" class="btn btn-outline-primary mt-auto rounded-pill w-100 fw-bold">View Details</a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12 text-center py-5">
                    <p class="text-muted fs-4">No products found at the moment.</p>
                </div>
            <% } %>
        </div>
    </main>

    <!-- Bootstrap JS and Custom JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/app.js"></script>
</body>
</html>
