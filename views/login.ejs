<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="page-shell">
    <%- include('partials/header', { activePage, currentUser }) %>
    <main class="container mt-5 pt-5 mb-5 section-space" style="min-height: 70vh;">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-xl-5">
                <div class="floating-panel p-4 p-md-5 reveal">
                    <span class="hero-chip">Welcome back</span>
                    <h1 class="display-6 fw-bold mt-3 mb-2">Login</h1>
                    <p class="soft-text mb-4">Sign in to manage your shopping experience and continue where you left off.</p>

                    <% if (errors && errors.general) { %>
                        <div class="alert alert-danger rounded-4"><%= errors.general %></div>
                    <% } %>

                    <form action="/login" method="POST" class="needs-validation" novalidate>
                        <div class="mb-3">
                            <label for="email" class="form-label fw-semibold">Email</label>
                            <input type="email" class="form-control form-control-lg <%= errors.email ? 'is-invalid' : '' %>" id="email" name="email" value="<%= formData.email || '' %>" required>
                            <div class="invalid-feedback"><%= errors.email || 'Please enter a valid email.' %></div>
                        </div>
                        <div class="mb-4">
                            <label for="password" class="form-label fw-semibold">Password</label>
                            <input type="password" class="form-control form-control-lg <%= errors.password ? 'is-invalid' : '' %>" id="password" name="password" required>
                            <div class="invalid-feedback"><%= errors.password || 'Please enter your password.' %></div>
                        </div>
                        <div class="d-flex gap-3 flex-wrap">
                            <button type="submit" class="btn btn-primary px-4 py-3 fw-bold" data-loading-text="Signing in...">Login</button>
                            <a href="/register" class="btn btn-outline-secondary px-4 py-3 fw-bold">Create account</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>
    <%- include('partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/app.js"></script>
</body>
</html>
