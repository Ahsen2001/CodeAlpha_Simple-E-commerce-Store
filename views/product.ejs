<%- include('partials/header') %>

<div class="container my-5 py-5 pb-xl-8">
    <!-- Breadcrumb for navigation context -->
    <nav aria-label="breadcrumb" class="mb-5">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-muted text-decoration-none">Home</a></li>
            <li class="breadcrumb-item"><a href="/products" class="text-muted text-decoration-none">Shop</a></li>
            <li class="breadcrumb-item active fw-medium" aria-current="page"><%= product.name %></li>
        </ol>
    </nav>

    <div class="row gx-5 align-items-center">
        <!-- Product Image Showcase -->
        <div class="col-lg-6 mb-5 mb-lg-0">
            <div class="product-showcase shadow-sm rounded-4 overflow-hidden position-relative bg-light">
                <img src="<%= product.image %>" class="img-fluid w-100 detail-img" alt="<%= product.name %>">
            </div>
        </div>
        
        <!-- Product Details Panel -->
        <div class="col-lg-5 offset-lg-1">
            <div class="d-flex flex-column h-100 details-panel">
                <h1 class="display-5 fw-bold mb-3 product-title"><%= product.name %></h1>
                <p class="fs-2 text-dark fw-bold mb-4 product-price">$<%= product.price.toFixed(2) %></p>
                
                <hr class="mb-4 opacity-25">
                
                <h5 class="fw-semibold mb-3">Product Description</h5>
                <p class="lead text-muted mb-5 product-desc" style="font-size: 1.1rem; line-height: 1.8;">
                    <%= product.description %>
                </p>
                
                <div class="mt-auto pt-3">
                    <form action="/cart/add" method="POST" class="d-flex gap-3">
                        <input type="hidden" name="productId" value="<%= product.id %>">
                        <button type="submit" class="btn btn-dark btn-lg flex-grow-1 rounded-pill depth-btn py-3 fs-5 fw-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-cart-plus me-2 mb-1" viewBox="0 0 16 16">
                                <path d="M9 5.5a.5.5 0 0 0-1 0V7H6.5a.5.5 0 0 0 0 1H8v1.5a.5.5 0 0 0 1 0V8h1.5a.5.5 0 0 0 0-1H9z"/>
                                <path d="M.5 1a.5.5 0 0 0 0 1h1.11l.401 1.607 1.498 7.985A.5.5 0 0 0 4 12h1a2 2 0 1 0 0 4 2 2 0 0 0 0-4h7a2 2 0 1 0 0 4 2 2 0 0 0 0-4h1a.5.5 0 0 0 .491-.408l1.5-8A.5.5 0 0 0 14.5 3H2.89l-.405-1.621A.5.5 0 0 0 2 1zm3.915 10L3.102 4h10.796l-1.313 7zM6 14a1 1 0 1 1-2 0 1 1 0 0 1 2 0zm7 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
                            </svg>
                            Add to Cart
                        </button>
                    </form>
                    <p class="text-center mt-3 text-muted" style="font-size: 0.85rem;">
                        Free shipping on orders over $500. Returns within 30 days.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
