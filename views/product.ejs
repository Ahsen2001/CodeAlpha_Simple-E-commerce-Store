<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="<%= product.description %>">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    
    <style>
        .product-image-container {
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }
        .product-image-container img {
            transition: transform 0.7s ease;
        }
        .product-image-container:hover img {
            transform: scale(1.05);
        }
        .add-to-cart-btn {
            padding: 1rem 2rem;
            font-size: 1.1rem;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg glass-nav fixed-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">🛍️ LuxeStore</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link cart-icon" href="/cart" id="cartToggle">
                            🛒 <span class="badge rounded-pill bg-primary" id="cartCount">0</span>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="container mt-5 pt-5 mb-5">
        <div class="row align-items-center py-5 g-5">
            <div class="col-md-6">
                <div class="product-image-container bg-white">
                    <img src="<%= product.image %>" alt="<%= product.name %>" class="img-fluid w-100 object-fit-cover" style="min-height: 500px; max-height: 600px;">
                </div>
            </div>
            <div class="col-md-6">
                <nav aria-label="breadcrumb" class="mb-4">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Home</a></li>
                        <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Shop</a></li>
                        <li class="breadcrumb-item active" aria-current="page"><%= product.name %></li>
                    </ol>
                </nav>
                
                <div class="d-flex align-items-center mb-3">
                    <span class="badge bg-light text-dark border me-2 fs-6"><i class="text-warning">★</i> <%= product.rating %> / 5.0</span>
                    <span class="text-success fw-bold small">In Stock</span>
                </div>
                
                <h1 class="display-5 fw-bold mb-3"><%= product.name %></h1>
                <p class="display-6 text-primary fw-bold mb-4">$<%= product.price.toFixed(2) %></p>
                
                <div class="mb-4">
                    <h5 class="fw-bold mb-2">Description</h5>
                    <p class="text-muted fs-5 lh-base"><%= product.description %></p>
                </div>
                
                <hr class="my-4">
                
                <div class="d-flex gap-3 mt-4">
                    <div class="input-group" style="width: 130px;">
                        <button class="btn btn-outline-secondary px-3" type="button" id="btnMinus">-</button>
                        <input type="text" class="form-control text-center fw-bold" id="productQuantity" value="1" readonly>
                        <button class="btn btn-outline-secondary px-3" type="button" id="btnPlus">+</button>
                    </div>
                    <button class="btn btn-primary add-to-cart-btn flex-grow-1 fw-bold rounded-pill shadow-sm" onclick="addToCart(<%= product.id %>, '<%= product.name.replace(/'/g, '\\\'') %>', <%= product.price %>, '<%= product.image %>')">
                        Add to Cart 🛒
                    </button>
                </div>
                
                <!-- Progressive disclosure for specs (modern UX) -->
                <div class="accordion mt-5" id="productAccordion">
                    <div class="accordion-item border-0 border-bottom bg-transparent">
                        <h2 class="accordion-header">
                            <button class="accordion-button bg-transparent fw-bold shadow-none px-0" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne">
                                Shipping & Returns
                            </button>
                        </h2>
                        <div id="collapseOne" class="accordion-collapse collapse" data-bs-parent="#productAccordion">
                            <div class="accordion-body px-0 text-muted">
                                Free standard shipping on all orders over $100. Returns are accepted within 30 days of purchase in original packaging.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/app.js"></script>
    <script>
        // Micro-interactions logic for the product page
        document.getElementById('btnMinus').addEventListener('click', () => {
            const qty = document.getElementById('productQuantity');
            if(parseInt(qty.value) > 1) qty.value = parseInt(qty.value) - 1;
        });
        document.getElementById('btnPlus').addEventListener('click', () => {
            const qty = document.getElementById('productQuantity');
            if(parseInt(qty.value) < 10) qty.value = parseInt(qty.value) + 1;
        });
        
        function addToCart(id, name, price, image) {
            const quantity = document.getElementById('productQuantity').value;
            
            // Interaction with the global app.js CartManager
            CartManager.addToCart({
                id: id,
                name: name,
                price: parseFloat(price),
                image: image
            }, quantity);
            
            // Haptic-like visual feedback
            const btn = document.querySelector('.add-to-cart-btn');
            const originalText = btn.innerHTML;
            btn.innerHTML = 'Added! ✓';
            btn.classList.replace('btn-primary', 'btn-success');
            
            // Pulse the cart icon in navbar
            const cartIcon = document.getElementById('cartToggle');
            cartIcon.style.transform = 'scale(1.3)';
            setTimeout(() => cartIcon.style.transform = 'scale(1)', 200);
            
            setTimeout(() => {
                btn.innerHTML = originalText;
                btn.classList.replace('btn-success', 'btn-primary');
            }, 2000);
        }
    </script>
</body>
</html>
