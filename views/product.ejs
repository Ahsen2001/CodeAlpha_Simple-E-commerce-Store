<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="<%= product.description %>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .product-image-container { border-radius: 12px; overflow: hidden; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05); }
        .product-image-container img { transition: transform 0.7s ease; }
        .product-image-container:hover img { transform: scale(1.05); }
        .add-to-cart-btn { padding: 1rem 2rem; font-size: 1.1rem; transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); }
    </style>
</head>
<body class="page-shell">
    <%- include('partials/header', { activePage }) %>
    <main class="container mt-5 pt-5 mb-5 section-space">
        <div class="row align-items-center py-5 g-5">
            <div class="col-md-6 reveal"><div class="product-image-container bg-white floating-panel p-3"><img src="<%= product.image %>" alt="<%= product.name %>" class="img-fluid w-100 object-fit-cover" style="min-height: 500px; max-height: 600px;"></div></div>
            <div class="col-md-6 reveal stagger-1">
                <nav aria-label="breadcrumb" class="mb-4"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/" class="text-decoration-none">Home</a></li><li class="breadcrumb-item"><a href="/" class="text-decoration-none">Shop</a></li><li class="breadcrumb-item active" aria-current="page"><%= product.name %></li></ol></nav>
                <div class="d-flex align-items-center gap-3 mb-3 flex-wrap"><span class="rating-pill"><%= product.rating %> / 5.0</span><span class="d-inline-flex align-items-center gap-2 text-success fw-bold small"><span class="status-dot"></span>In Stock</span></div>
                <h1 class="display-5 fw-bold mb-3"><%= product.name %></h1>
                <p class="display-6 text-primary fw-bold mb-4">$<%= product.price.toFixed(2) %></p>
                <div class="mb-4"><h5 class="fw-bold mb-2">Description</h5><p class="text-muted fs-5 lh-base"><%= product.description %></p></div>
                <hr class="my-4">
                <div class="d-flex gap-3 mt-4 flex-wrap">
                    <div class="input-group" style="width: 130px;"><button class="btn btn-outline-secondary px-3" type="button" id="btnMinus">-</button><input type="text" class="form-control text-center fw-bold" id="productQuantity" value="1" readonly><button class="btn btn-outline-secondary px-3" type="button" id="btnPlus">+</button></div>
                    <button class="btn btn-primary add-to-cart-btn flex-grow-1 fw-bold rounded-pill shadow-sm" id="addToCartButton" data-product-id="<%= product.id %>" data-product-name="<%= product.name %>" data-product-price="<%= product.price %>" data-product-image="<%= product.image %>" data-loading-text="Adding...">Add to Cart</button>
                </div>
                <div class="accordion mt-5 floating-panel p-3" id="productAccordion"><div class="accordion-item border-0 border-bottom bg-transparent"><h2 class="accordion-header"><button class="accordion-button bg-transparent fw-bold shadow-none px-0" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne">Shipping & Returns</button></h2><div id="collapseOne" class="accordion-collapse collapse" data-bs-parent="#productAccordion"><div class="accordion-body px-0 text-muted">Free standard shipping on all orders over $100. Returns are accepted within 30 days of purchase in original packaging.</div></div></div></div>
            </div>
        </div>
    </main>
    <%- include('partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/app.js"></script>
    <script>
        document.getElementById('btnMinus').addEventListener('click', () => { const qty = document.getElementById('productQuantity'); if (parseInt(qty.value, 10) > 1) qty.value = parseInt(qty.value, 10) - 1; });
        document.getElementById('btnPlus').addEventListener('click', () => { const qty = document.getElementById('productQuantity'); if (parseInt(qty.value, 10) < 10) qty.value = parseInt(qty.value, 10) + 1; });
        document.getElementById('addToCartButton').addEventListener('click', (event) => {
            const button = event.currentTarget;
            addToCart(parseInt(button.dataset.productId, 10), button.dataset.productName, parseFloat(button.dataset.productPrice), button.dataset.productImage);
        });
        function addToCart(id, name, price, image) {
            const quantity = document.getElementById('productQuantity').value;
            CartManager.addToCart({ id: id, name: name, price: parseFloat(price), image: image }, quantity);
            const btn = document.getElementById('addToCartButton');
            const originalText = btn.dataset.originalText || btn.innerHTML;
            btn.innerHTML = 'Added!';
            btn.classList.replace('btn-primary', 'btn-success');
            btn.disabled = true;
            const cartIcon = document.getElementById('cartToggle');
            cartIcon.style.transform = 'scale(1.3)';
            setTimeout(() => { cartIcon.style.transform = 'scale(1)'; }, 200);
            setTimeout(() => {
                btn.innerHTML = originalText;
                btn.classList.replace('btn-success', 'btn-primary');
                btn.disabled = false;
            }, 2000);
        }
    </script>
</body>
</html>
